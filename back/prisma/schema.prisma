generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductCategory {
  roupas
  tenis
  controles
  eletronicos
  diversos
}

enum PaymentMethod {
  dinheiro
  credito
  debito
  fiado
}

enum UserRole {
  SUPER_ADMIN
  STORE_USER
}

model Store {
  id        String   @id @default(uuid())
  name     String
  slug     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users    User[]
  products Product[]
  sales    Sale[]
  stockLogs StockLog[]
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         UserRole
  storeId      String?
  store        Store?    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  resetTokens  PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Product {
  id            String         @id
  storeId       String
  store         Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name          String
  sku           String?
  barcode       String?
  stock         Int            @default(0)
  priceCents    Int
  costCents     Int?
  category      ProductCategory
  imageUrl      String?
  brand         String?
  model         String?
  size          String?
  color         String?
  description   String?
  controlNumber String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Sale {
  id            String         @id
  storeId       String
  store         Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt     DateTime
  totalCents    Int
  itemsCount    Int
  customerName  String?
  customerPhone String?
  updatedAt     DateTime       @default(now())
  items        SaleItem[]
  payments      SalePayment[]
}

model SaleItem {
  id             String  @id
  saleId         String
  productId      String
  productName    String
  sku            String?
  qty            Int
  unitPriceCents Int
  lineTotalCents Int
  sale           Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model SalePayment {
  id          String        @id
  saleId      String
  method      PaymentMethod
  amountCents Int
  sale        Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model StockLog {
  id          String   @id
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  delta       Int
  reason      String?
  createdAt   DateTime
}
