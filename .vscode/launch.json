{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Docker: Compose Up",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Next.js: Web",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/front",
      "preLaunchTask": "front: install",
      "env": { "NODE_OPTIONS": "--inspect" },
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "Electron: Desktop",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["${workspaceFolder}/front/node_modules/electron/cli.js", "."],
      "cwd": "${workspaceFolder}/front",
      "console": "integratedTerminal",
      "preLaunchTask": "next: build"
    },
    {
      "name": "Android: Emulador",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["cap", "run", "android"],
      "cwd": "${workspaceFolder}/front",
      "console": "integratedTerminal",
      "preLaunchTask": "build + cap sync"
    },
    {
      "name": "Android: Dispositivo",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["cap", "run", "android"],
      "cwd": "${workspaceFolder}/front",
      "console": "integratedTerminal",
      "preLaunchTask": "build + cap sync"
    }
  ]
}
