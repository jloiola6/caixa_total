{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "front: install",
      "type": "shell",
      "command": "pnpm install",
      "options": { "cwd": "${workspaceFolder}/front" },
      "group": "none",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "next: build",
      "type": "shell",
      "command": "pnpm run build",
      "options": { "cwd": "${workspaceFolder}/front" },
      "group": "build",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "cap: sync",
      "type": "shell",
      "command": "npx cap sync",
      "options": { "cwd": "${workspaceFolder}/front" },
      "dependsOn": "next: build",
      "group": "build",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "build + cap sync",
      "dependsOrder": "sequence",
      "dependsOn": ["next: build", "cap: sync"],
      "group": "build"
    }
  ]
}
